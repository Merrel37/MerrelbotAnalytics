{
  "manifest_version": 3,
  "name": "Buff Sell History Collector",
  "version": "1.0.2",
  "description": "Collects Buff sell_order history into minimal JSON.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://buff.163.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}